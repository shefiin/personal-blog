PORT=3001
NODE_ENV=development

MONGO_URL=mongodb://127.0.0.1:27017/code-context-auth
REDIS_URL=redis://127.0.0.1:6379

JWT_KEY=replace-with-a-long-random-secret
REFRESH_SECRET=replace-with-another-long-random-secret
ADMIN_LOGIN_ATTEMPT_LIMIT=10
ADMIN_LOGIN_LOCK_TIME_SECONDS=180
ADMIN_SEED_NAME=Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace-with-a-strong-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=no-reply@codecontext.local
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

#############################################
# NODE AND MICROSERVICES
#############################################

# Node modules for all services
services/**/node_modules/

# Build output
services/**/dist/
services/**/build/

# TS build cache
services/**/.tscache/
services/**/.turbo/

# Local service logs
services/**/logs/
logs/
*.log

# PM2 logs (if used later)
.pids

#############################################
# ENVIRONMENT FILES (Never commit secrets)
#############################################

# Global env files
*.env
*.env.*.local

# Service-specific env files
services/**/.env
services/**/.env.*

# Infrastructure envs
infrastructure/**/.env

#############################################
# DOCKER & DATABASE VOLUMES
#############################################

# If you ever bind local folders
mongo-data/
redis-data/
docker-data/

# Generic data dirs
data/
infrastructure/data/

# Docker Compose override files
docker-compose.override.yml
docker-compose.*.yml

#############################################
# OS & EDITOR FILES
#############################################

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Linux temp files
*.swp
*.swo

#############################################
# TEMPORARY FILES
#############################################

tmp/
temp/
.cache/
.nyc_output/

#############################################
# MISC
#############################################

# TypeScript
*.tsbuildinfo

# Coverage output
coverage/

# Debugger dumps
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency-related
package-lock.json
pnpm-lock.yaml
yarn.lock
